{
  "name": "stringent",
  "version": "0.0.5",
  "description": "A smart and type-safe expression parser with compile-time validation, inference and runtime evaluation",
  "keywords": [
    "parser",
    "expression",
    "typescript",
    "type-level",
    "evaluator"
  ],
  "homepage": "https://github.com/eralmansouri/stringent#readme",
  "bugs": {
    "url": "https://github.com/eralmansouri/stringent/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eralmansouri/stringent.git"
  },
  "license": "MIT",
  "author": "Essam Almansouri",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:package": "publint && attw --pack . --profile esm-only",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build && pnpm check:package"
  },
  "dependencies": {
    "@sinclair/parsebox": "^0.11.1",
    "arktype": "^2.2.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^22.10.5",
    "publint": "^0.3.12",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
